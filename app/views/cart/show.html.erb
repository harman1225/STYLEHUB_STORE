<h1>Your Cart</h1>

<% @products.each do |product| %>
  <div>
    <h5><%= product.name %></h5>

    <%= form_with url: update_cart_path(product), method: :patch do %>
      <%= number_field_tag :quantity, session[:cart][product.id.to_s] %>
      <%= submit_tag "Update" %>
    <% end %>

    <%= button_to "Remove", remove_cart_path(product), method: :delete %>
  </div>
<% end %>
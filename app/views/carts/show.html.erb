<div class="container py-5">
  <h1 class="mb-4 fw-bold text-center">Your Shopping Cart</h1>
  <%= breadcrumbs ["Home", root_path], ["Cart", cart_path] %>
  <% if @products.blank? || @products.empty? %>
    <div class="alert alert-info text-center shadow-sm rounded-4">
      Your cart is empty.
    </div>
    <div class="text-center">
      <%= link_to "Continue Shopping", root_path, class: "btn btn-dark px-4" %>
    </div>
  <% else %>
    <% grand_total = 0 %>

    <div class="row g-4">
      <% @products.each do |product| %>
        <% quantity = @cart[product.id.to_s].to_i %>
        <% item_total = product.price * quantity %>
        <% grand_total += item_total %>

        <div class="col-12">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
              <div class="row align-items-center">
                <div class="col-md-5">
                  <h4 class="fw-bold mb-2"><%= product.name %></h4>
                  <p class="text-muted mb-1">Price: $<%= sprintf("%.2f", product.price) %></p>
                  <p class="fw-semibold mb-0">Item Total: $<%= sprintf("%.2f", item_total) %></p>
                </div>

                <div class="col-md-4 mt-3 mt-md-0">
                  <%= form_with url: update_cart_path(product), method: :patch, local: true, class: "d-flex gap-2" do %>
                    <%= number_field_tag :quantity, quantity, min: 1, class: "form-control" %>
                    <%= submit_tag "Update", class: "btn btn-warning fw-semibold" %>
                  <% end %>
                </div>

                <div class="col-md-3 mt-3 mt-md-0 text-md-end">
                  <%= button_to "Remove", remove_cart_path(product), method: :delete,
                      class: "btn btn-outline-danger fw-semibold" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mt-4">
      <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center p-4">
        <div>
          <h4 class="fw-bold mb-1">Cart Total</h4>
          <h3 class="text-success mb-0">$<%= sprintf("%.2f", grand_total) %></h3>
        </div>

        <div class="mt-3 mt-md-0 d-flex gap-2">
          <%= link_to "Continue Shopping", root_path, class: "btn btn-outline-dark px-4" %>
          <%= link_to "Proceed to Checkout", checkout_path, class: "btn btn-success px-4 fw-semibold" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow border-0 rounded-4">
        <div class="card-body p-5">

          <h2 class="text-center fw-bold mb-4">Create Account</h2>

          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-semibold" %>
              <%= f.email_field :email, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label fw-semibold" %>
              <%= f.password_field :password, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, class: "form-label fw-semibold" %>
              <%= f.password_field :password_confirmation, class: "form-control" %>
            </div>

            <div class="d-grid mb-3">
              <%= f.submit "Sign up", class: "btn btn-success btn-lg" %>
            </div>

          <% end %>

          <div class="text-center">
            <%= link_to "Already have an account? Login", new_session_path(resource_name) %>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Stylehub Store" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Stylehub Store">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= render "shared/navbar" %>
    <%= render "shared/flash" %>
    <%= render "shared/breadcrumbs" %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <style>
      body {
        background: #f8fafc;
      }

      .main-navbar {
        background: rgba(15, 23, 42, 0.96);
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      }

      .main-navbar .navbar-brand {
        font-size: 1.35rem;
      }

      .main-navbar .nav-link {
        color: rgba(255,255,255,0.9) !important;
        font-weight: 500;
        margin-right: 0.3rem;
      }

      .main-navbar .nav-link:hover {
        color: white !important;
      }

      .main-navbar .dropdown-menu {
        border: none;
        border-radius: 14px;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12);
        padding: 0.65rem;
      }

      .main-navbar .dropdown-item {
        border-radius: 10px;
        padding: 0.55rem 0.8rem;
      }

      .main-navbar .dropdown-item:hover {
        background: #f1f5f9;
      }

      .nav-btn {
        border-radius: 999px;
        padding: 0.45rem 1rem;
        font-weight: 600;
      }

      .page-wrap {
        padding-top: 1.25rem;
        padding-bottom: 2rem;
      }

      .alert {
        border: none;
        border-radius: 14px;
      }
    </style>
  </head>

  <body>
    <% if request.path.start_with?("/admin") %>
      <div class="container-fluid py-2 px-3 bg-dark text-white d-flex justify-content-between align-items-center">
        <div class="fw-semibold">Admin Panel</div>

        <div class="d-flex gap-2">
          <%= link_to "Home", root_path, class: "btn btn-sm btn-light" %>
          <%= link_to "Products", root_path, class: "btn btn-sm btn-outline-light" %>
          <%= link_to "Admin Logout", destroy_admin_user_session_path, data: { turbo_method: :delete }, class: "btn btn-sm btn-danger" %>
        </div>
      </div>

      <%= yield %>

    <% else %>
      <nav class="navbar navbar-expand-lg navbar-dark main-navbar sticky-top">
        <div class="container">
          <%= link_to "Stylehub Store", root_path, class: "navbar-brand fw-bold" %>

          <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center">
              <li class="nav-item">
                <%= link_to "Home", root_path, class: "nav-link" %>
              </li>

              <li class="nav-item">
                <%= link_to "Products", root_path, class: "nav-link" %>
              </li>

              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="categoriesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  Categories
                </a>
                <ul class="dropdown-menu" aria-labelledby="categoriesDropdown">
                  <li><%= link_to "Men", products_path(category: 1), class: "dropdown-item" %></li>
                  <li><%= link_to "Women", products_path(category: 2), class: "dropdown-item" %></li>
                  <li><%= link_to "Kids", products_path(category: 3), class: "dropdown-item" %></li>
                  <li><%= link_to "Accessories", products_path(category: 4), class: "dropdown-item" %></li>
                </ul>
              </li>

              <li class="nav-item">
                <%= link_to "About", "/about", class: "nav-link" %>
              </li>

              <li class="nav-item">
                <%= link_to "Contact", "/contact", class: "nav-link" %>
              </li>

              <li class="nav-item">
                <%= link_to "My Orders", orders_path, class: "nav-link" %>
              </li>
            </ul>

            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center">
              <li class="nav-item me-lg-2 mb-2 mb-lg-0">
                <%= link_to "Cart", "/cart", class: "btn btn-success nav-btn" %>
              </li>

              <li class="nav-item me-lg-2 mb-2 mb-lg-0">
                <%= link_to "Admin", "/admin", class: "btn btn-outline-light nav-btn" %>
              </li>

              <% if user_signed_in? %>
                <li class="nav-item">
                  <span class="nav-link text-white-50"><%= current_user.email %></span>
                </li>
                <li class="nav-item">
                  <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
                </li>
              <% else %>
                <li class="nav-item">
                  <%= link_to "Login", new_user_session_path, class: "nav-link" %>
                </li>
                <li class="nav-item">
                  <%= link_to "Sign Up", new_user_registration_path, class: "nav-link" %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </nav>

      <div class="container page-wrap">
        <% if notice.present? %>
          <div class="alert alert-success mt-3"><%= notice %></div>
        <% end %>

        <% if alert.present? %>
          <div class="alert alert-danger mt-3"><%= alert %></div>
        <% end %>

        <%= yield %>
      </div>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
<div class="container py-5">
<%= breadcrumbs ["Home", root_path], ["My Orders", orders_path] %>
  <h1 class="fw-bold mb-4 text-center">My Orders</h1>

  <% if @orders.blank? %>
    <div class="alert alert-info text-center shadow-sm rounded-4">
      No orders found yet.
    </div>
    <div class="text-center">
      <%= link_to "Continue Shopping", root_path, class: "btn btn-dark px-4" %>
    </div>
  <% else %>
    <div class="row g-4">
      <% @orders.each do |order| %>
        <div class="col-12">
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
              <div class="row align-items-center">
                <div class="col-md-8">
                  <h4 class="fw-bold mb-2">Order #<%= order.id %></h4>
                  <p class="mb-1"><strong>Status:</strong> <%= order.status %></p>
                  <p class="mb-1"><strong>GST:</strong> $<%= sprintf("%.2f", order.gst || 0) %></p>
                  <p class="mb-1"><strong>PST:</strong> $<%= sprintf("%.2f", order.pst || 0) %></p>
                  <p class="mb-1"><strong>HST:</strong> $<%= sprintf("%.2f", order.hst || 0) %></p>
                  <p class="mb-0"><strong>Total:</strong> $<%= sprintf("%.2f", order.total || 0) %></p>
                </div>

                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                  <%= link_to "View Details", order_path(order), class: "btn btn-outline-dark" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
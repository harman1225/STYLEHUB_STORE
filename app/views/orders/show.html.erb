<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0">Order #<%= @order.id %></h1>
    <%= link_to "Back to Orders", orders_path, class: "btn btn-outline-secondary" %>
  </div>
  <%= breadcrumbs ["Home", root_path], ["My Orders", orders_path], ["Order ##{@order.id}", order_path(@order)] %>
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-3">Ordered Items</h4>

          <% @order.order_items.each do |item| %>
            <div class="d-flex justify-content-between align-items-center border-bottom py-3">
              <div>
                <div class="fw-semibold"><%= item.product&.name || "Product" %></div>
                <small class="text-muted">Quantity: <%= item.quantity %></small>
              </div>
              <div class="fw-semibold">
                $<%= sprintf("%.2f", item.price * item.quantity) %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-3">Order Summary</h4>
          <p><strong>Status:</strong> <%= @order.status %></p>
          <p><strong>GST:</strong> $<%= sprintf("%.2f", @order.gst || 0) %></p>
          <p><strong>PST:</strong> $<%= sprintf("%.2f", @order.pst || 0) %></p>
          <p><strong>HST:</strong> $<%= sprintf("%.2f", @order.hst || 0) %></p>
          <p><strong>Address:</strong> <%= @order.address %></p>
          <p><strong>Status:</strong> <%= @order.status %></p>
          <p><strong>Payment ID:</strong> <%= @order.payment_id %></p>
          <hr>
          <h4 class="text-success fw-bold">Total: $<%= sprintf("%.2f", @order.total || 0) %></h4>
        </div>
      </div>
    </div>
  </div>
</div>
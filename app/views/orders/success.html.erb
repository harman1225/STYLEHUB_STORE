<div class="container py-5">
  <div class="card border-0 shadow-sm rounded-4 mx-auto" style="max-width: 700px;">
    <div class="card-body p-5 text-center">
      <h1 class="fw-bold text-success mb-3">Order Placed Successfully</h1>
      <p class="lead">Thank you for shopping with StyleHub.</p>
      <p>Your order has been created and saved.</p>

      <div class="mt-4 d-flex justify-content-center gap-2 flex-wrap">
        <%= link_to "Continue Shopping", root_path, class: "btn btn-dark px-4" %>
        <%= link_to "View This Order", order_path(@order), class: "btn btn-outline-success px-4" %>
        <%= link_to "My Orders", orders_path, class: "btn btn-outline-dark px-4" %>
      </div>
    </div>
  </div>
</div>
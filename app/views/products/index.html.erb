<div class="products-page container py-5">

  <!-- Page Heading -->
  <div class="text-center mb-5">
    <h1 class="display-4 fw-bold">All Products</h1>
    <p class="text-muted">Discover the latest fashion trends at StyleHub</p>
  </div>

  <!-- Breadcrumbs (correct place) -->
  <%= render "shared/breadcrumbs" %>

  <!-- Search Box -->
  <div class="search-box card border-0 shadow-sm rounded-4 p-4 mb-5">
    <h2 class="h3 fw-bold mb-4">Search Products</h2>

    <%= form_with url: products_path, method: :get, local: true do %>
      <div class="row g-3 align-items-center">
        <div class="col-md-5">
          <%= text_field_tag :keyword,
              params[:keyword],
              placeholder: "Search products...",
              class: "form-control form-control-lg rounded-3" %>
        </div>

        <div class="col-md-4">
          <%= select_tag :category_id,
              options_for_select([["All Categories", ""]] + @categories.map { |c| [c.name, c.id] }, params[:category_id]),
              class: "form-select form-select-lg rounded-3" %>
        </div>

        <div class="col-md-3">
          <%= submit_tag "Search",
              class: "btn btn-primary btn-lg w-100 rounded-3 fw-semibold" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Browse by Category -->
  <div class="card border-0 shadow-sm rounded-4 p-4 mb-5">
    <h2 class="h3 fw-bold mb-3">Browse by Category</h2>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All Products", products_path, class: "btn btn-outline-secondary btn-sm" %>
      <% @categories.each do |category| %>
        <%= link_to category.name,
            products_path(category_id: category.id),
            class: "btn btn-outline-secondary btn-sm" %>
      <% end %>
    </div>
  </div>

  <!-- Filters -->
  <div class="card border-0 shadow-sm rounded-4 p-4 mb-5">
    <h2 class="h3 fw-bold mb-3">Filters</h2>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "All", products_path, class: "btn btn-outline-secondary btn-sm" %>
      <%= link_to "New Products", products_path(filter: "new"), class: "btn btn-outline-secondary btn-sm" %>
      <%= link_to "Recently Updated", products_path(filter: "updated"), class: "btn btn-outline-secondary btn-sm" %>
      <%= link_to "On Sale", products_path(filter: "sale"), class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>

  <!-- Products Grid -->
  <div class="row g-4">
    <% @products.each do |product| %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border shadow-sm rounded-4">
          <% if product.respond_to?(:image) && product.image.present? %>
          <%= image_tag product.image.variant(resize_to_fill: [300, 220]),                class: "card-img-top rounded-top-4",
                style: "height: 220px; object-fit: cover;" %>
          <% else %>
            <div class="d-flex align-items-center justify-content-center bg-light text-muted rounded-top-4"
                 style="height: 220px;">
              No Image
            </div>
          <% end %>

          <div class="card-body d-flex flex-column">
          <h5 class="fw-bold mb-2 text-dark">              <%= link_to product.name, product_path(product), class: "text-decoration-none text-primary" %>
            </h5>

            <% if product.respond_to?(:category) && product.category.present? %>
              <p class="mb-1 small">
                <strong>Category:</strong> <%= product.category.name %>
              </p>
            <% end %>

            <p class="fw-bold text-success fs-5 mb-2">
              $<%= sprintf("%.2f", product.price) %>
            </p>

            <% if product.respond_to?(:description) && product.description.present? %>
              <p class="text-muted small mb-3">
                <%= truncate(product.description, length: 90) %>
              </p>
            <% end %>

            <% if product.respond_to?(:on_sale?) && product.on_sale? %>
              <span class="badge bg-danger mb-3 align-self-start">On Sale</span>
            <% end %>

            <div class="mt-auto d-flex gap-2">
              <%= link_to "View Product",
                  product_path(product),
                  class: "btn btn-outline-primary btn-sm" %>

              <%= button_to "Add to Cart",
                  add_to_cart_path(product),
                  method: :post,
                  class: "btn btn-success btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Pagination -->
  <div class="mt-4 d-flex justify-content-center">
    <%= paginate @products %>
  </div>
</div>
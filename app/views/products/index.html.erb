<div class="products-page container py-5">
  <div class="text-center mb-5">
    <h1 class="display-4 fw-bold">All Products</h1>
    <p class="text-muted">Discover the latest fashion trends at StyleHub</p>
  </div>

  <div class="search-box card border-0 shadow-sm rounded-4 p-4 mb-5">
    <h2 class="h3 fw-bold mb-4">Search Products</h2>

    <%= form_with url: products_path, method: :get, local: true do %>
      <div class="row g-3 align-items-center">
        <div class="col-md-5">
          <%= text_field_tag :search, params[:search], placeholder: "Search products...", class: "form-control form-control-lg rounded-3" %>
        </div>

        <div class="col-md-4">
          <%= select_tag :category,
              options_for_select([["All Categories", ""]] + Category.pluck(:name, :id), params[:category]),
              class: "form-select form-select-lg rounded-3" %>
        </div>

        <div class="col-md-3">
          <%= submit_tag "Search", class: "btn btn-success btn-lg w-100 rounded-3 fw-semibold" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mb-5">
    <h2 class="fw-bold mb-3">Categories</h2>
    <div class="d-flex flex-wrap gap-2">
      <% Category.all.each do |category| %>
        <%= link_to category.name, products_path(category: category.id), class: "btn btn-outline-success rounded-pill px-4 py-2" %>
      <% end %>
    </div>
  </div>

  <div class="mb-5">
    <h2 class="fw-bold mb-3">Filters</h2>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to "New", products_path(filter: "new"), class: "btn btn-dark rounded-pill px-4 py-2" %>
      <%= link_to "Recently Updated", products_path(filter: "recent"), class: "btn btn-outline-dark rounded-pill px-4 py-2" %>
      <%= link_to "On Sale", products_path(filter: "sale"), class: "btn btn-danger rounded-pill px-4 py-2" %>
    </div>
  </div>

  <div class="row g-4">
    <% @products.each do |product| %>
      <div class="col-md-6 col-lg-4 col-xl-3">
        <div class="card product-card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
          <% if product.respond_to?(:image) && product.image.present? %>
            <%= image_tag product.image, class: "card-img-top product-img" %>
          <% else %>
            <div class="product-placeholder d-flex align-items-center justify-content-center">
              <span class="text-muted">No Image</span>
            </div>
          <% end %>

          <div class="card-body d-flex flex-column p-4">
            <h4 class="card-title fw-bold mb-2"><%= product.name %></h4>

            <% if product.respond_to?(:category) && product.category.present? %>
              <p class="text-muted small mb-2"><%= product.category.name %></p>
            <% end %>

            <p class="fs-4 fw-bold text-success mb-3">$<%= sprintf("%.2f", product.price) %></p>

            <% if product.respond_to?(:on_sale?) && product.on_sale? %>
              <span class="badge bg-danger mb-3 align-self-start">On Sale</span>
            <% end %>

            <div class="mt-auto d-grid gap-2">
              <%= link_to "View Product", product_path(product), class: "btn btn-dark rounded-3" %>
              <%= button_to "Add to Cart", add_to_cart_path(product), method: :post, class: "btn btn-success rounded-3" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!--  PAGINATION -->
<%= paginate @products %>